---
const mediumUrl = "https://medium.com/@harendra21";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Page not found</title>
    <script define:vars={{ mediumUrl }}>
      if (window.location.pathname.startsWith("/articles")) {
        window.location.replace(mediumUrl);
      }
    </script>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: system-ui, sans-serif;
        background: #f8f5ef;
        color: #1f1b16;
      }
      a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Page not found</h1>
      <p>
        Try the <a href="/">homepage</a> or visit
        <a href={mediumUrl}>Medium</a>.
      </p>
    </main>
  </body>
</html>
