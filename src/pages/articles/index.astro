---
const mediumUrl = "https://medium.com/@harendra21";
const redirectContent = `0; url=${mediumUrl}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={redirectContent} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to Medium</title>
    <script define:vars={{ mediumUrl }}>
      window.location.replace(mediumUrl);
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={mediumUrl}>{mediumUrl}</a>...</p>
  </body>
</html>
