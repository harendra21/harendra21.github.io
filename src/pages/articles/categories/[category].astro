---
import { getCollection } from "astro:content";

const mediumUrl = "https://medium.com/@harendra21";

export async function getStaticPaths() {
  const articles = await getCollection("blog");

  return articles.map(article => ({
    params: { category: article.data.category },
  }));
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${mediumUrl}`} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to Medium</title>
    <script is:inline>
      window.location.replace({JSON.stringify(mediumUrl)});
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={mediumUrl}>{mediumUrl}</a>...</p>
  </body>
</html>
