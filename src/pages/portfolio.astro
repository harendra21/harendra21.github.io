---

<BaseLayout title="Portfolio" description="Projects done">
  <main class="flex min-h-[80vh] flex-auto flex-col" transition:animate="slide">
    <TopLayout>
      <h2
        class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight first:mt-0"
      >
        Projects worked on
      </h2>
    </TopLayout>
    <BottomLayout>
      <div class="flex w-full flex-wrap justify-center gap-2">
        {
          PROFESSIONAL_PROJECTS.map((entry: any) => (
            <ProjectCard
              key={entry?.sys?.id}
              href={entry?.link}
              heading={entry?.name}
              subheading={entry?.description}
              imagePath={entry?.image}
              altText={entry?.name}
              class="w-full sm:w-2/5"
            />
          ))
        }
      </div>
    </BottomLayout>
  </main>

  <main class="flex min-h-[80vh] flex-auto flex-col" transition:animate="slide">
    <TopLayout>
      <h2
        class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight first:mt-0"
      >
        Personal Projects
      </h2>
    </TopLayout>
    <BottomLayout>
      <div class="flex w-full flex-wrap justify-center gap-2">
        {
          PERSONAL_PROJECTS.map((entry: any) => (
            <ProjectCard
              key={entry?.sys?.id}
              href={entry?.link}
              heading={entry?.name}
              subheading={entry?.description}
              imagePath={entry?.image}
              altText={entry?.name}
              class="w-full sm:w-2/5"
            />
          ))
        }
      </div>
    </BottomLayout>
  </main>
</BaseLayout>
