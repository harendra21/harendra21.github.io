---
import LouaiAvatar from "@/components/ui/louai-avatar.astro";
import Badge from "@/components/ui/badge.astro";

import { PROFILE_INFO } from "@/lib/constants/profile";
import { SOCIAL_LINKS } from "@/lib/constants";
import { buttonVariants } from "@/lib/utils";

const primaryCtaClass = buttonVariants({ variant: "default", size: "lg" });
const secondaryCtaClass = buttonVariants({ variant: "outline", size: "lg" });
const tertiaryCtaClass = buttonVariants({ variant: "ghost", size: "lg" });

const heroSummary =
  "I build production web apps and AI-powered systems with Golang, Angular, AWS, and GCP. I turn backend complexity, agent workflows, and product delivery into experiences that feel fast, dependable, and easy to use.";

const highlights = [
  "8+ years building web products.",
  "Production-focused engineering.",
  "Code reviews and team mentoring.",
] as const;

const focusAreas = [
  "Golang",
  "Angular",
  "AWS, GCP",
  "Kubernetes",
  "AI Agents",
  "MCP Servers",
  "RAG",
] as const;
---

<section class="screen-line-after relative overflow-hidden px-4 py-8 md:border-x md:px-6 md:py-10 lg:px-8">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(59,130,246,0.12),_transparent_38%),radial-gradient(circle_at_bottom_left,_rgba(0,0,0,0.06),_transparent_32%)] dark:bg-[radial-gradient(circle_at_top_right,_rgba(59,130,246,0.18),_transparent_38%),radial-gradient(circle_at_bottom_left,_rgba(255,255,255,0.05),_transparent_32%)]"
  />

  <div class="relative grid gap-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(320px,0.85fr)] lg:items-start">
    <div class="space-y-6">
      <Badge>Backend, full-stack, and AI engineering</Badge>

      <div class="space-y-4">
        <p class="font-mono text-xs uppercase tracking-[0.28em] text-muted-foreground">
          Portfolio, Resume, Projects
        </p>

        <div class="space-y-3">
          <h1 class="max-w-[12ch] text-5xl font-black leading-[0.9] tracking-tight sm:text-6xl lg:text-[4.8rem]">
            <span class="block">Harendra Kumar</span>
            <span class="block">Kanojiya</span>
          </h1>

          <p class="max-w-2xl text-lg font-semibold text-foreground/85 sm:text-xl">
            {PROFILE_INFO.role}
          </p>
        </div>

        <p class="max-w-xl text-base leading-7 text-muted-foreground sm:text-lg sm:leading-8">
          {heroSummary}
        </p>

        <div class="grid gap-3 pt-2 sm:grid-cols-3">
          <div class="rounded-2xl border border-border/70 bg-card/70 p-3">
            <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">Focus</p>
            <p class="mt-1 text-sm font-semibold">Reliable software</p>
          </div>
          <div class="rounded-2xl border border-border/70 bg-card/70 p-3">
            <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">Strength</p>
            <p class="mt-1 text-sm font-semibold">Backend systems and product delivery</p>
          </div>
          <div class="rounded-2xl border border-border/70 bg-card/70 p-3">
            <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">Current</p>
            <p class="mt-1 text-sm font-semibold">AI workflows and MCP tooling</p>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          href={PROFILE_INFO.resumeLink}
          target="_blank"
          rel="noopener noreferrer"
          class={primaryCtaClass}
        >
          Download Resume
        </a>
        <a
          href={`mailto:${PROFILE_INFO.email}`}
          class={secondaryCtaClass}
        >
          Email Me
        </a>
        <a href="/projects" class={tertiaryCtaClass}>
          See Selected Work
        </a>
      </div>

      <div class="flex flex-wrap gap-2 pt-1">
        {focusAreas.map(item => (
          <Badge>{item}</Badge>
        ))}
      </div>
    </div>

    <aside class="relative lg:pt-4">
      <div class="rounded-[2rem] border border-border/70 bg-card/95 p-5 shadow-[0_20px_60px_rgba(0,0,0,0.08)] backdrop-blur dark:shadow-[0_20px_60px_rgba(0,0,0,0.32)]">
        <div class="flex items-center justify-between gap-3">
          <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-muted-foreground">
            Visual intro
          </p>

          <Badge>Open now</Badge>
        </div>

        <div class="mt-4">
          <LouaiAvatar
            className="mx-auto w-full max-w-[18rem]"
            size={640}
            priority={true}
          />
        </div>

        <div class="mt-5 border-t border-border/70 pt-4">
          <p class="text-sm font-semibold text-foreground">
            Building reliable products and AI systems that are easy to ship and easy to use.
          </p>

          <div class="mt-3 grid gap-2">
            {highlights.map(item => (
              <div class="flex items-center gap-2 rounded-2xl border border-border/70 bg-background/70 px-3 py-2 text-sm text-muted-foreground">
                <div class="size-1.5 shrink-0 rounded-full bg-primary" />
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="mt-5 border-t border-border/70 pt-4">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted-foreground">
            Quick links
          </p>

          <div class="mt-3 flex flex-wrap gap-2">
            {SOCIAL_LINKS.map(link => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-border/70 bg-background/70 px-3 py-2 text-sm font-medium text-foreground/80 transition-colors hover:bg-accent hover:text-foreground"
              >
                <link.icon className="size-4" />
                {link.name}
              </a>
            ))}
            <a
              href={`mailto:${PROFILE_INFO.email}`}
              class="inline-flex items-center gap-2 rounded-full border border-border/70 bg-background/70 px-3 py-2 text-sm font-medium text-foreground/80 transition-colors hover:bg-accent hover:text-foreground"
            >
              {PROFILE_INFO.email}
            </a>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>
