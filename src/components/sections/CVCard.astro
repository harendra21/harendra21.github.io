---
import { Download } from 'lucide-react'
import Card from '../Card.astro'
import { Button } from '../ui/button'

const PDF = '/Harendra Kumar - 7.0 Years Exp.pdf'
---

<Card colSpan="md:col-span-2" rowSpan="md:row-span-4" title="Resume">
  <div class="mt-4 flex w-full justify-center">
    <div
      class="card card-compact md:w-112 lg:w-128 w-96 gap-2 border-[oklch(var(--p))] transition-all"
    >
      <figure>
        <object data={PDF} type="application/pdf" width="100%" height="250px"
        ></object>
      </figure>
      <div class="mt-4 flex flex-col gap-2">
        <p class="text-sm text-muted-foreground">
          View and download my resume by clicking on the button below
        </p>
        <div class="card-actions mt-2 flex w-full items-center justify-center">
          <a target="_blank" href={PDF}>
            <Button>
              Download Resume &nbsp;
              <Download />
            </Button>
          </a>
        </div>
      </div>
    </div>
  </div>
</Card>
