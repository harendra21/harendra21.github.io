---
import { ChevronRightIcon, FolderCodeIcon } from "lucide-react";
import type { CollectionEntry } from "astro:content";
import MarkdownRenderer from "@/components/ui/markdown-renderer.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<a
  href={`/projects/${project.id}`}
  class="group flex h-full flex-col gap-3 border-b border-border/80 p-4 transition-colors hover:bg-accent/25 focus-visible:bg-accent/25 focus-visible:outline-none md:min-h-[220px] md:border-r"
>
  <div class="flex items-start justify-between gap-3">
    <div class="space-y-1">
      <div class="flex items-center gap-2">
        <FolderCodeIcon className="size-4 shrink-0 text-muted-foreground transition-colors group-hover:text-foreground" />
        <h3 class="text-base font-semibold leading-tight underline-offset-4 group-hover:underline">
          {project.data.name}
        </h3>
      </div>

      <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">
        {project.data.type === "core" ? "Production" : "Side project"}
      </p>
    </div>

    <ChevronRightIcon className="mt-1 size-4 shrink-0 text-muted-foreground transition-transform duration-150 group-hover:translate-x-1" />
  </div>

  <MarkdownRenderer
    className="line-clamp-2 text-sm leading-6 font-medium text-muted-foreground"
    content={project.data.description}
  />

  <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
    {project.data.technologies.slice(0, 4).map(technology => (
      <span class="inline-flex items-center rounded-full border border-border/70 bg-background/70 px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
        {technology}
      </span>
    ))}
  </div>
</a>
