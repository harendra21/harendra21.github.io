---
import { SOCIAL_LINKS } from "@/lib/constants";
import { PROFILE_INFO } from "@/lib/constants/profile";
---

<footer class="w-full border-t border-border/70 bg-background/80 backdrop-blur">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-4 px-4 py-6 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8"
  >
    <div class="space-y-1">
      <p class="text-sm font-semibold tracking-tight">
        {PROFILE_INFO.displayName}
      </p>
      <p class="max-w-2xl text-sm leading-6 text-foreground/70">
        Open to backend, full-stack, and AI engineering roles. Reach out at
        <a
          href={`mailto:${PROFILE_INFO.email}`}
          class="font-medium text-primary underline underline-offset-4"
        >
          {PROFILE_INFO.email}
        </a>
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-4">
      <a
        href={PROFILE_INFO.resumeLink}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full border border-border/70 bg-card/70 px-3 py-1.5 text-sm font-medium text-foreground/80 transition-colors hover:bg-accent hover:text-foreground"
      >
        Resume
      </a>

      {
        SOCIAL_LINKS.map(link => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.name}
            class="text-foreground/70 transition-colors hover:text-foreground"
          >
            <link.icon className="size-4" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
