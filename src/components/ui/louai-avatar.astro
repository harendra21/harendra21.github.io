---
import { Image } from "astro:assets";
import ImgAvatar from "@/assets/harendra.png";
import { PROFILE_INFO } from "@/lib/constants/profile";

interface Props {
  className?: string;
  size?: number;
  priority?: boolean;
}

const {
  className,
  size = 100, // Default size if not provided
  priority = false,
} = Astro.props;

---

<div
  class:list={[
    "relative aspect-square overflow-hidden rounded-[1.75rem] border border-border/70 bg-card shadow-[0_24px_80px_rgba(0,0,0,0.14)]",
    className,
  ]}
>
  <Image
    class="h-full w-full object-cover object-center"
    src={ImgAvatar}
    alt={`${PROFILE_INFO.displayName}'s avatar`}
    widths={[size, size * 2]}
    sizes={`(max-width: ${size}px) 100vw, ${size}px`}
    quality={85}
    loading={priority ? "eager" : "lazy"}
    decoding="async"
  />
</div>
