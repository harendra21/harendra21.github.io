---
import { Picture } from "astro:assets";
import ImgAvatar from "@/assets/harendra-1_mkyefp.jpg";
import { PROFILE_INFO } from "@/lib/constants/profile";

interface Props {
  className?: string;
  size?: number;
  priority?: boolean;
}

const {
  className,
  size = 100, // Default size if not provided
  priority = false,
} = Astro.props;

// Determine image formats for fallback and webp
const formats = ["avif", "webp"];
---

<div
  class:list={[
    "relative aspect-square overflow-hidden rounded-[1.5rem] border border-border/70 bg-card shadow-[0_20px_60px_rgba(0,0,0,0.12)]",
    className,
  ]}
>
  <Picture
    class="h-full w-full object-cover object-center"
    src={ImgAvatar}
    widths={[size, size * 2]}
    sizes={`(max-width: ${size}px) 100vw, ${size}px`}
    formats={formats}
    alt={`${PROFILE_INFO.displayName}'s avatar`}
    quality="mid"
    loading={priority ? "eager" : "lazy"}
    decoding="async"
  />
</div>
