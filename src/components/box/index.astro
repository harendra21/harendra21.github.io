---
interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section
  class:list={[
    "overflow-hidden rounded-[1.75rem] border border-border/70 bg-card/80 shadow-[0_20px_60px_rgba(0,0,0,0.05)] backdrop-blur",
    "md:border-x",
    className,
  ]}
>
  <slot />
</section>
